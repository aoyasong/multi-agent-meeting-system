{
  "id": "meeting",
  "name": "Multi-Agent Meeting Plugin",
  "description": "多Agent协同会议系统，支持头脑风暴、需求评审、技术评审、项目启动等场景",
  "version": "1.0.0",
  "contracts": {
    "tools": [
      "meeting_create",
      "meeting_start",
      "meeting_end",
      "meeting_get",
      "meeting_list",
      "agenda_add_item",
      "agenda_list_items",
      "agenda_next_item",
      "speaking_request",
      "speaking_grant",
      "speaking_release",
      "speaking_status",
      "voting_create",
      "voting_cast",
      "voting_get_result",
      "voting_end",
      "voting_override",
      "recording_take_note",
      "recording_tag_insight",
      "recording_get_transcript",
      "output_generate_summary",
      "output_generate_action_items",
      "output_export"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "storageDir": {
        "type": "string",
        "description": "会议数据存储目录，默认为 ~/.openclaw/meetings"
      },
      "pollIntervalMs": {
        "type": "number",
        "description": "消息轮询间隔（毫秒）",
        "default": 5000,
        "minimum": 1000,
        "maximum": 30000
      },
      "agentTimeoutMs": {
        "type": "number",
        "description": "Agent响应超时（毫秒）",
        "default": 30000,
        "minimum": 5000,
        "maximum": 120000
      },
      "votingWindows": {
        "type": "object",
        "description": "投票窗口配置（秒）",
        "additionalProperties": false,
        "properties": {
          "simple": {
            "type": "number",
            "default": 180,
            "description": "简单决策窗口（秒）"
          },
          "moderate": {
            "type": "number",
            "default": 300,
            "description": "中等复杂度窗口（秒）"
          },
          "complex": {
            "type": "number",
            "default": 600,
            "description": "复杂决策窗口（秒）"
          }
        }
      }
    }
  },
  "uiHints": {
    "storageDir": {
      "label": "存储目录",
      "help": "会议数据的存储位置"
    },
    "pollIntervalMs": {
      "label": "轮询间隔",
      "help": "消息同步的轮询间隔（毫秒），默认5000"
    },
    "agentTimeoutMs": {
      "label": "Agent超时",
      "help": "等待Agent响应的超时时间（毫秒），默认30000"
    }
  }
}
